// MONTRA — Customer Receipt & Order Management
// Prisma schema. Postgres (Neon). Money stored as Decimal(12,2) in LKR.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (PgBouncer) for app queries
  directUrl = env("DIRECT_URL") // direct for migrations
}

// ----------------------------- Enums -----------------------------
enum Role {
  ADMIN
  STAFF
}

enum ReceiptStatus {
  DRAFT
  FINALIZED
}

// Production workflow stages an order moves through after the receipt is finalized.
enum OrderStatus {
  FABRIC_SELECTION
  CUTTING
  PRODUCTION
  QUALITY_CHECK
  IRON_PACKING
  DELIVERY
  // Terminal stage, past Delivery — set automatically at creation when a
  // receipt (e.g. from a bulk-upload review) is already fully paid, since
  // that's a strong signal the whole order is already done. Can also be set
  // manually like any other stage.
  COMPLETED
}

// Payment progress, derived from amounts paid vs. total due.
enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

// Bulk (normal multi-unit) vs Sample (single-unit development for QC).
// A sample can be converted to bulk, or deleted if the customer rejects it.
enum OrderType {
  BULK
  SAMPLE
}

// Which top-level folder (Men's / Women's) a receipt files under, both
// in-app and in the synced computer folder.
enum Category {
  MEN
  WOMEN
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  OTHER
}

enum AuditAction {
  CUSTOMER_CREATED
  CUSTOMER_UPDATED
  RECEIPT_CREATED
  RECEIPT_UPDATED
  RECEIPT_FINALIZED
  PDF_GENERATED
  ORDER_STATUS_CHANGED
  VERSION_CREATED
  PAYMENT_RECORDED
  RECEIPT_DELETED
  CUSTOMER_DELETED
  EXPENSE_RECORDED
  EXPENSE_DELETED
  EXPENSE_UPDATED
  EXPENSE_FINALIZED
  EXPENSE_UNFINALIZED
  BUSINESS_REGISTERED
  BUSINESS_UPDATED
  BUSINESS_LOGO_UPDATED
  BUSINESS_API_KEY_UPDATED
  STAFF_INVITE_CREATED
  STAFF_INVITE_REVOKED
  STAFF_INVITE_REDEEMED
  ORDER_CONFIRMED
  BUSINESS_PLAN_CHANGED
  BUSINESS_SUBSCRIPTION_STATUS_CHANGED
}

// A gate-able dashboard section — used by Plan.enabledSections to control
// what a business can see/use. Deliberately whole-section granularity, not
// finer per-action flags (e.g. "can create receipts but not delete them").
enum Section {
  CUSTOMERS
  RECEIPTS
  ORDERS
  PRODUCTION
  EXPENSES
  INCOME
  TEAM
  AUDIT_LOG
  SETTINGS
}

// ACTIVE/TRIAL both count as "in good standing" (full plan access); EXPIRED
// and CANCELLED both drop a business to zero sections regardless of its
// plan — see getBusinessAccess() in src/lib/section-access.ts. No payment
// provider wired up yet: a Super Admin sets this by hand for now (see
// Business.subscriptionStatus) — real billing can flip it automatically later
// without any of the enforcement code needing to change.
enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
}

// A named bundle of enabled sections — e.g. "Full Access", or a future
// "Basic"/"Pro" tier. Businesses are assigned one by a Super Admin (see
// Business.planId). Changing a plan's sections instantly changes access for
// every business on that plan.
model Plan {
  id             String    @id @default(cuid())
  name           String    @unique
  enabledSections Section[]
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  businesses Business[]
}

// ----------------------------- Users -----------------------------
// Mirror of the Clerk user. We never trust the client for identity —
// the Clerk session is the source of truth; this row caches display info.
// Role is no longer here — a person's role can differ per business (e.g.
// Admin of their own business, Staff if invited into someone else's), so it
// lives on BusinessMember instead.
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  // Platform-level role, unrelated to any business membership — can manage
  // every business's plan/subscription and customize what sections exist at
  // all. Never settable via any UI/API; only ever flipped by hand in the
  // database. See requireSuperAdmin() in lib/auth.ts.
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Which business this user is currently acting within. Only meaningful to
  // read once a membership row confirms they still belong to it — see
  // requireBusiness() in lib/auth.ts.
  activeBusinessId String?
  activeBusiness   Business? @relation("ActiveBusiness", fields: [activeBusinessId], references: [id], onDelete: SetNull)

  memberships         BusinessMember[]
  staffInvitesCreated StaffInvite[]        @relation("StaffInviteCreatedBy")
  staffInvitesUsed    StaffInvite[]        @relation("StaffInviteUsedBy")
  createdReceipts     Receipt[]            @relation("ReceiptCreatedBy")
  finalizedReceipts   Receipt[]            @relation("ReceiptFinalizedBy")
  versions            ReceiptVersion[]
  orderChanges        OrderStatusHistory[]
  auditLogs           AuditLog[]
  customerInvites     CustomerInvite[]
  payments            Payment[]
  expenseRecords      ExpenseRecord[]      @relation("ExpenseRecordedBy")
  finalizedExpenses   ExpenseRecord[]      @relation("ExpenseFinalizedBy")
}

// ---------------------------- Business ----------------------------
// A tenant. Every Customer/Receipt/CustomerInvite/AuditLog belongs to
// exactly one — see requireBusiness() for how the active one is resolved
// per request.
model Business {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String?
  // Encrypted (see src/lib/crypto/secret-box.ts) — a business's own Gemini
  // API key for the receipt-photo OCR import, so heavy usage on one tenant
  // doesn't exhaust the shared default key's free-tier quota for everyone
  // else. Null means "use the shared default key".
  geminiApiKeyEncrypted String?
  // Per-business invoice-number counter — each business's receipt numbers
  // start at 1 and increment independently of every other business's. Only
  // incremented when a receipt is actually confirmed (see Receipt.receiptNumber),
  // so abandoned/never-paid receipts never burn a number.
  lastReceiptNumber Int      @default(0)

  // Entitlements: which plan this business is on (controls which sections it
  // can see/use — see getBusinessAccess()) and whether its subscription is
  // currently in good standing. No payment provider yet — a Super Admin sets
  // both by hand for now.
  planId             String
  plan               Plan               @relation(fields: [planId], references: [id])
  subscriptionStatus SubscriptionStatus @default(ACTIVE)
  subscriptionRenewsAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members         BusinessMember[]
  staffInvites    StaffInvite[]
  activeForUsers  User[]           @relation("ActiveBusiness")
  customers       Customer[]
  receipts        Receipt[]
  customerInvites CustomerInvite[]
  auditLogs       AuditLog[]
}

// Membership + role, per business — a person can belong to more than one.
model BusinessMember {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @default(STAFF)
  createdAt  DateTime @default(now())

  @@unique([businessId, userId])
  @@index([userId])
}

// Single-use, expiring invite links for bringing staff into a business —
// same shape as CustomerInvite, generalized for team members instead.
model StaffInvite {
  id          String    @id @default(cuid())
  businessId  String
  business    Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  token       String    @unique
  role        Role      @default(STAFF)
  usedAt      DateTime?
  usedById    String?
  usedBy      User?     @relation("StaffInviteUsedBy", fields: [usedById], references: [id])
  expiresAt   DateTime?
  createdById String
  createdBy   User      @relation("StaffInviteCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime  @default(now())

  @@index([token])
  @@index([businessId])
}

// --------------------------- Customers ---------------------------
model Customer {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name       String
  address    String?
  phone      String?
  // A second/alternate contact number — some customers give two. Purely for
  // staff reachability; not snapshotted onto receipts or printed on the PDF
  // (those stay as they are, keyed off the primary phone only).
  otherPhone String?
  email      String?
  nic        String? // NIC / identification number
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  receipts Receipt[]
  invite   CustomerInvite?

  @@index([businessId])
  @@index([name])
  @@index([phone])
  @@index([otherPhone])
  @@index([email])
  @@index([createdAt])
}

// ----------------- Customer self-registration invites -----------------
// One-time tokenized links sent to a prospective customer so they fill in
// their own details. A token is single-use (usedAt) and time-limited
// (expiresAt). Sharing a spent link can't create more customers.
model CustomerInvite {
  id         String    @id @default(cuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  token      String    @unique
  usedAt     DateTime?
  expiresAt  DateTime?

  // The customer this invite produced, once submitted.
  customerId String?   @unique
  customer   Customer? @relation(fields: [customerId], references: [id])

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([businessId])
  @@index([token])
}

// ---------------------------- Receipts ---------------------------
model Receipt {
  id String @id @default(cuid())
  // Null until confirmed (see receiptService — a new BULK order with no
  // payment yet stays "Unconfirmed" and never gets a number until the advance
  // is paid). Unique per business, not globally — each business's numbers
  // start at 1 independently (Business.lastReceiptNumber).
  receiptNumber Int?

  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  // Snapshot of customer fields at issue time (so edits to the customer
  // record never silently rewrite a finalized document).
  custName    String
  custAddress String?
  custPhone   String?
  custEmail   String?

  date  DateTime @default(now())
  notes String?

  // Payment information block (the four boxes on the template)
  paymentMethods PaymentMethod[]

  // Monetary fields (LKR). Derived in the service layer, persisted for fast reads.
  subtotal         Decimal @default(0) @db.Decimal(12, 2)
  adjustmentsTotal Decimal @default(0) @db.Decimal(12, 2)
  totalDue         Decimal @default(0) @db.Decimal(12, 2)
  advanceAmount    Decimal @default(0) @db.Decimal(12, 2)
  amountPaid       Decimal @default(0) @db.Decimal(12, 2)
  balance          Decimal @default(0) @db.Decimal(12, 2)

  status        ReceiptStatus @default(DRAFT)
  orderStatus   OrderStatus   @default(FABRIC_SELECTION)
  paymentStatus PaymentStatus @default(UNPAID)
  orderType     OrderType     @default(BULK)
  category      Category      @default(WOMEN)

  // Permanent public tracking-page token — set only for BULK orders (null
  // for SAMPLE). Never expires; customers use it to check production status.
  trackingToken String? @unique

  currentVersion Int       @default(1)
  finalizedAt    DateTime?
  finalizedById  String?
  finalizedBy    User?     @relation("ReceiptFinalizedBy", fields: [finalizedById], references: [id])

  createdById String
  createdBy   User   @relation("ReceiptCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         ReceiptItem[]
  adjustments   ReceiptAdjustment[]
  versions      ReceiptVersion[]
  orderHistory  OrderStatusHistory[]
  payments      Payment[]
  expenseRecord ExpenseRecord?

  @@unique([businessId, receiptNumber])
  @@index([status])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([orderType])
  @@index([customerId])
  @@index([createdAt])
}

// ------------------------- Payment ledger ------------------------
// One row per instalment recorded against a finalized receipt. The
// receipt's amountPaid is kept as the running sum of these entries;
// paymentStatus is recomputed from total paid vs. totalDue.
model Payment {
  id           String         @id @default(cuid())
  receiptId    String
  receipt      Receipt        @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  amount       Decimal        @db.Decimal(12, 2)
  method       PaymentMethod?
  note         String?
  paidAt       DateTime       @default(now())
  recordedById String
  recordedBy   User           @relation(fields: [recordedById], references: [id])
  createdAt    DateTime       @default(now())

  @@index([receiptId])
}

// ------------------------- Expense ledger -------------------------
// One structured cost record per receipt (fabric/sewing/accessory/other).
// Profit is stored (auto-calculated client-side, but overridable) rather
// than always recomputed, so a manual override survives. Only finalized
// records are picked up by the Income/P&L page — unfinalized ones are
// invisible there until an admin locks them in.
model ExpenseRecord {
  id        String  @id @default(cuid())
  receiptId String  @unique
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  // Bulk orders track all six; Sample orders only use fabric/patternMaking/
  // production — the other three simply stay 0 and unedited for a sample.
  fabricExpense        Decimal @default(0) @db.Decimal(12, 2)
  patternMakingExpense Decimal @default(0) @db.Decimal(12, 2)
  cuttingExpense       Decimal @default(0) @db.Decimal(12, 2) // Bulk only
  productionExpense    Decimal @default(0) @db.Decimal(12, 2)
  accessoryExpense     Decimal @default(0) @db.Decimal(12, 2) // Bulk only
  otherExpense         Decimal @default(0) @db.Decimal(12, 2) // Bulk only

  profit Decimal @default(0) @db.Decimal(12, 2)

  finalized     Boolean   @default(false)
  finalizedAt   DateTime?
  finalizedById String?
  finalizedBy   User?     @relation("ExpenseFinalizedBy", fields: [finalizedById], references: [id])

  recordedById String
  recordedBy   User     @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])
  updatedAt    DateTime @updatedAt
  createdAt    DateTime @default(now())

  @@index([finalized])
}

model ReceiptItem {
  id          String  @id @default(cuid())
  receiptId   String
  receipt     Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  // Production tracking is per item, not per receipt — an order's overall
  // status (on Receipt) is a cached rollup of these.
  orderStatus OrderStatus          @default(FABRIC_SELECTION)
  history     OrderStatusHistory[]

  @@index([receiptId])
}

// Free-form +/- lines such as "Pattern" (-6,600 in the sample receipt).
model ReceiptAdjustment {
  id        String  @id @default(cuid())
  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  label     String
  amount    Decimal @db.Decimal(12, 2) // negative = discount
  sortOrder Int     @default(0)

  @@index([receiptId])
}

// ------------------------ Version history ------------------------
// Every edit to a FINALIZED receipt snapshots the full prior state.
model ReceiptVersion {
  id            String   @id @default(cuid())
  receiptId     String
  receipt       Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  versionNumber Int
  snapshot      Json // full receipt + items + adjustments at this version
  changeSummary String?
  modifiedById  String
  modifiedBy    User     @relation(fields: [modifiedById], references: [id])
  createdAt     DateTime @default(now())

  @@unique([receiptId, versionNumber])
  @@index([receiptId])
}

// --------------------- Order status history ----------------------
// itemId is nullable only because rows created before per-item tracking was
// added are receipt-wide and have no single item to attribute to; every row
// created from here on always has one.
model OrderStatusHistory {
  id          String       @id @default(cuid())
  receiptId   String
  receipt     Receipt      @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  itemId      String?
  item        ReceiptItem? @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  note        String?
  changedById String
  changedBy   User         @relation(fields: [changedById], references: [id])
  createdAt   DateTime     @default(now())

  @@index([receiptId])
  @@index([itemId])
}

// ----------------------------- Audit -----------------------------
model AuditLog {
  id         String      @id @default(cuid())
  businessId String
  business   Business    @relation(fields: [businessId], references: [id], onDelete: Cascade)
  actorId    String
  actor      User        @relation(fields: [actorId], references: [id])
  action     AuditAction
  entityType String // "Customer" | "Receipt" | "Order" ...
  entityId   String
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([businessId])
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}
