// MONTRA — Customer Receipt & Order Management
// Prisma schema. Postgres (Neon). Money stored as Decimal(12,2) in LKR.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")        // pooled (PgBouncer) for app queries
  directUrl = env("DIRECT_URL")          // direct for migrations
}

// ----------------------------- Enums -----------------------------
enum Role {
  ADMIN
  STAFF
}

enum ReceiptStatus {
  DRAFT
  FINALIZED
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  OTHER
}

enum AuditAction {
  CUSTOMER_CREATED
  CUSTOMER_UPDATED
  RECEIPT_CREATED
  RECEIPT_UPDATED
  RECEIPT_FINALIZED
  PDF_GENERATED
  ORDER_STATUS_CHANGED
  VERSION_CREATED
}

// ----------------------------- Users -----------------------------
// Mirror of the Clerk user. We never trust the client for identity —
// the Clerk session is the source of truth; this row caches role + display.
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdReceipts   Receipt[]            @relation("ReceiptCreatedBy")
  finalizedReceipts Receipt[]            @relation("ReceiptFinalizedBy")
  versions          ReceiptVersion[]
  orderChanges      OrderStatusHistory[]
  auditLogs         AuditLog[]
}

// --------------------------- Customers ---------------------------
model Customer {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  nic       String?  // NIC / identification number
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipts Receipt[]

  @@index([name])
  @@index([phone])
  @@index([email])
  @@index([createdAt])
}

// ---------------------------- Receipts ---------------------------
model Receipt {
  id            String @id @default(cuid())
  receiptNumber Int    @unique @default(autoincrement())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  // Snapshot of customer fields at issue time (so edits to the customer
  // record never silently rewrite a finalized document).
  custName    String
  custAddress String?
  custPhone   String?
  custEmail   String?

  date  DateTime @default(now())
  notes String?

  // Payment information block (the four boxes on the template)
  paymentMethods PaymentMethod[]

  // Monetary fields (LKR). Derived in the service layer, persisted for fast reads.
  subtotal         Decimal @default(0) @db.Decimal(12, 2)
  adjustmentsTotal Decimal @default(0) @db.Decimal(12, 2)
  totalDue         Decimal @default(0) @db.Decimal(12, 2)
  advanceAmount    Decimal @default(0) @db.Decimal(12, 2)
  amountPaid       Decimal @default(0) @db.Decimal(12, 2)
  balance          Decimal @default(0) @db.Decimal(12, 2)

  status      ReceiptStatus @default(DRAFT)
  orderStatus OrderStatus   @default(PENDING)

  currentVersion Int       @default(1)
  finalizedAt    DateTime?
  finalizedById  String?
  finalizedBy    User?     @relation("ReceiptFinalizedBy", fields: [finalizedById], references: [id])

  createdById String
  createdBy   User   @relation("ReceiptCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         ReceiptItem[]
  adjustments   ReceiptAdjustment[]
  versions      ReceiptVersion[]
  orderHistory  OrderStatusHistory[]

  @@index([status])
  @@index([orderStatus])
  @@index([customerId])
  @@index([createdAt])
  @@index([receiptNumber])
}

model ReceiptItem {
  id          String  @id @default(cuid())
  receiptId   String
  receipt     Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  lineTotal   Decimal @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  @@index([receiptId])
}

// Free-form +/- lines such as "Pattern" (-6,600 in the sample receipt).
model ReceiptAdjustment {
  id        String  @id @default(cuid())
  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  label     String
  amount    Decimal @db.Decimal(12, 2) // negative = discount
  sortOrder Int     @default(0)

  @@index([receiptId])
}

// ------------------------ Version history ------------------------
// Every edit to a FINALIZED receipt snapshots the full prior state.
model ReceiptVersion {
  id            String   @id @default(cuid())
  receiptId     String
  receipt       Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  versionNumber Int
  snapshot      Json     // full receipt + items + adjustments at this version
  changeSummary String?
  modifiedById  String
  modifiedBy    User     @relation(fields: [modifiedById], references: [id])
  createdAt     DateTime @default(now())

  @@unique([receiptId, versionNumber])
  @@index([receiptId])
}

// --------------------- Order status history ----------------------
model OrderStatusHistory {
  id          String      @id @default(cuid())
  receiptId   String
  receipt     Receipt     @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  note        String?
  changedById String
  changedBy   User        @relation(fields: [changedById], references: [id])
  createdAt   DateTime    @default(now())

  @@index([receiptId])
}

// ----------------------------- Audit -----------------------------
model AuditLog {
  id         String      @id @default(cuid())
  actorId    String
  actor      User        @relation(fields: [actorId], references: [id])
  action     AuditAction
  entityType String      // "Customer" | "Receipt" | "Order" ...
  entityId   String
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}
