// MONTRA — Customer Receipt & Order Management
// Prisma schema. Postgres (Neon). Money stored as Decimal(12,2) in LKR.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")        // pooled (PgBouncer) for app queries
  directUrl = env("DIRECT_URL")          // direct for migrations
}

// ----------------------------- Enums -----------------------------
enum Role {
  ADMIN
  STAFF
}

enum ReceiptStatus {
  DRAFT
  FINALIZED
}

// Production workflow stages an order moves through after the receipt is finalized.
enum OrderStatus {
  FABRIC_SELECTION
  CUTTING
  PRODUCTION
  QUALITY_CHECK
  IRON_PACKING
  DELIVERY
}

// Payment progress, derived from amounts paid vs. total due.
enum PaymentStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

// Bulk (normal multi-unit) vs Sample (single-unit development for QC).
// A sample can be converted to bulk, or deleted if the customer rejects it.
enum OrderType {
  BULK
  SAMPLE
}

// Which top-level folder (Men's / Women's) a receipt files under, both
// in-app and in the synced computer folder.
enum Category {
  MEN
  WOMEN
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  OTHER
}

enum AuditAction {
  CUSTOMER_CREATED
  CUSTOMER_UPDATED
  RECEIPT_CREATED
  RECEIPT_UPDATED
  RECEIPT_FINALIZED
  PDF_GENERATED
  ORDER_STATUS_CHANGED
  VERSION_CREATED
  PAYMENT_RECORDED
  RECEIPT_DELETED
  CUSTOMER_DELETED
  EXPENSE_RECORDED
  EXPENSE_DELETED
  EXPENSE_UPDATED
  EXPENSE_FINALIZED
  EXPENSE_UNFINALIZED
}

// ----------------------------- Users -----------------------------
// Mirror of the Clerk user. We never trust the client for identity —
// the Clerk session is the source of truth; this row caches role + display.
model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String?
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdReceipts   Receipt[]            @relation("ReceiptCreatedBy")
  finalizedReceipts Receipt[]            @relation("ReceiptFinalizedBy")
  versions          ReceiptVersion[]
  orderChanges      OrderStatusHistory[]
  auditLogs         AuditLog[]
  customerInvites   CustomerInvite[]
  payments          Payment[]
  expenseRecords    ExpenseRecord[] @relation("ExpenseRecordedBy")
  finalizedExpenses ExpenseRecord[] @relation("ExpenseFinalizedBy")
}

// --------------------------- Customers ---------------------------
model Customer {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  email     String?
  nic       String?  // NIC / identification number
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  receipts Receipt[]
  invite   CustomerInvite?

  @@index([name])
  @@index([phone])
  @@index([email])
  @@index([createdAt])
}

// ----------------- Customer self-registration invites -----------------
// One-time tokenized links sent to a prospective customer so they fill in
// their own details. A token is single-use (usedAt) and time-limited
// (expiresAt). Sharing a spent link can't create more customers.
model CustomerInvite {
  id        String    @id @default(cuid())
  token     String    @unique
  usedAt    DateTime?
  expiresAt DateTime?

  // The customer this invite produced, once submitted.
  customerId String?   @unique
  customer   Customer? @relation(fields: [customerId], references: [id])

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())

  @@index([token])
}

// ---------------------------- Receipts ---------------------------
model Receipt {
  id            String @id @default(cuid())
  receiptNumber Int    @unique @default(autoincrement())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  // Snapshot of customer fields at issue time (so edits to the customer
  // record never silently rewrite a finalized document).
  custName    String
  custAddress String?
  custPhone   String?
  custEmail   String?

  date  DateTime @default(now())
  notes String?

  // Payment information block (the four boxes on the template)
  paymentMethods PaymentMethod[]

  // Monetary fields (LKR). Derived in the service layer, persisted for fast reads.
  subtotal         Decimal @default(0) @db.Decimal(12, 2)
  adjustmentsTotal Decimal @default(0) @db.Decimal(12, 2)
  totalDue         Decimal @default(0) @db.Decimal(12, 2)
  advanceAmount    Decimal @default(0) @db.Decimal(12, 2)
  amountPaid       Decimal @default(0) @db.Decimal(12, 2)
  balance          Decimal @default(0) @db.Decimal(12, 2)

  status        ReceiptStatus @default(DRAFT)
  orderStatus   OrderStatus   @default(FABRIC_SELECTION)
  paymentStatus PaymentStatus @default(UNPAID)
  orderType     OrderType     @default(BULK)
  category      Category      @default(WOMEN)

  // Permanent public tracking-page token — set only for BULK orders (null
  // for SAMPLE). Never expires; customers use it to check production status.
  trackingToken String? @unique

  currentVersion Int       @default(1)
  finalizedAt    DateTime?
  finalizedById  String?
  finalizedBy    User?     @relation("ReceiptFinalizedBy", fields: [finalizedById], references: [id])

  createdById String
  createdBy   User   @relation("ReceiptCreatedBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items         ReceiptItem[]
  adjustments   ReceiptAdjustment[]
  versions      ReceiptVersion[]
  orderHistory  OrderStatusHistory[]
  payments      Payment[]
  expenseRecord ExpenseRecord?

  @@index([status])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([orderType])
  @@index([customerId])
  @@index([createdAt])
  @@index([receiptNumber])
}

// ------------------------- Payment ledger ------------------------
// One row per instalment recorded against a finalized receipt. The
// receipt's amountPaid is kept as the running sum of these entries;
// paymentStatus is recomputed from total paid vs. totalDue.
model Payment {
  id           String         @id @default(cuid())
  receiptId    String
  receipt      Receipt        @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  amount       Decimal        @db.Decimal(12, 2)
  method       PaymentMethod?
  note         String?
  paidAt       DateTime       @default(now())
  recordedById String
  recordedBy   User           @relation(fields: [recordedById], references: [id])
  createdAt    DateTime       @default(now())

  @@index([receiptId])
}

// ------------------------- Expense ledger -------------------------
// One structured cost record per receipt (fabric/sewing/accessory/other).
// Profit is stored (auto-calculated client-side, but overridable) rather
// than always recomputed, so a manual override survives. Only finalized
// records are picked up by the Income/P&L page — unfinalized ones are
// invisible there until an admin locks them in.
model ExpenseRecord {
  id               String    @id @default(cuid())
  receiptId        String    @unique
  receipt          Receipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  // Bulk orders track all six; Sample orders only use fabric/patternMaking/
  // production — the other three simply stay 0 and unedited for a sample.
  fabricExpense        Decimal @default(0) @db.Decimal(12, 2)
  patternMakingExpense Decimal @default(0) @db.Decimal(12, 2)
  cuttingExpense       Decimal @default(0) @db.Decimal(12, 2) // Bulk only
  productionExpense    Decimal @default(0) @db.Decimal(12, 2)
  accessoryExpense     Decimal @default(0) @db.Decimal(12, 2) // Bulk only
  otherExpense         Decimal @default(0) @db.Decimal(12, 2) // Bulk only

  profit           Decimal   @default(0) @db.Decimal(12, 2)

  finalized        Boolean   @default(false)
  finalizedAt      DateTime?
  finalizedById    String?
  finalizedBy      User?     @relation("ExpenseFinalizedBy", fields: [finalizedById], references: [id])

  recordedById     String
  recordedBy       User      @relation("ExpenseRecordedBy", fields: [recordedById], references: [id])
  updatedAt        DateTime  @updatedAt
  createdAt        DateTime  @default(now())

  @@index([finalized])
}

model ReceiptItem {
  id          String      @id @default(cuid())
  receiptId   String
  receipt     Receipt     @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Decimal     @db.Decimal(12, 2)
  lineTotal   Decimal     @db.Decimal(12, 2)
  sortOrder   Int         @default(0)

  // Production tracking is per item, not per receipt — an order's overall
  // status (on Receipt) is a cached rollup of these.
  orderStatus OrderStatus @default(FABRIC_SELECTION)
  history     OrderStatusHistory[]

  @@index([receiptId])
}

// Free-form +/- lines such as "Pattern" (-6,600 in the sample receipt).
model ReceiptAdjustment {
  id        String  @id @default(cuid())
  receiptId String
  receipt   Receipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  label     String
  amount    Decimal @db.Decimal(12, 2) // negative = discount
  sortOrder Int     @default(0)

  @@index([receiptId])
}

// ------------------------ Version history ------------------------
// Every edit to a FINALIZED receipt snapshots the full prior state.
model ReceiptVersion {
  id            String   @id @default(cuid())
  receiptId     String
  receipt       Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  versionNumber Int
  snapshot      Json     // full receipt + items + adjustments at this version
  changeSummary String?
  modifiedById  String
  modifiedBy    User     @relation(fields: [modifiedById], references: [id])
  createdAt     DateTime @default(now())

  @@unique([receiptId, versionNumber])
  @@index([receiptId])
}

// --------------------- Order status history ----------------------
// itemId is nullable only because rows created before per-item tracking was
// added are receipt-wide and have no single item to attribute to; every row
// created from here on always has one.
model OrderStatusHistory {
  id          String       @id @default(cuid())
  receiptId   String
  receipt     Receipt      @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  itemId      String?
  item        ReceiptItem? @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fromStatus  OrderStatus?
  toStatus    OrderStatus
  note        String?
  changedById String
  changedBy   User         @relation(fields: [changedById], references: [id])
  createdAt   DateTime     @default(now())

  @@index([receiptId])
  @@index([itemId])
}

// ----------------------------- Audit -----------------------------
model AuditLog {
  id         String      @id @default(cuid())
  actorId    String
  actor      User        @relation(fields: [actorId], references: [id])
  action     AuditAction
  entityType String      // "Customer" | "Receipt" | "Order" ...
  entityId   String
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}
